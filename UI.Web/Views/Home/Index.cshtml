@model IEnumerable<Core.Concretes.DTOs.MakaleKartDto>

@{
    ViewData["Title"] = "Makale Listesi";
}

<h1>Makale Listesi</h1>

<p>
    <a asp-action="Create">Yeni Makale Ekle</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Kapak Görseli</th>
            <th>Başlık</th>
            <th>Kategori</th>
            <th>Yayınlanma Tarihi</th>
            <th>Etiketler</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@(item.KapakGorseliYolu ?? "/images/default.png")" class="img-thumbnail" style="width:5rem;" alt="@item.Baslik" />
                </td>
                <td>@item.Baslik</td>
                <td>@item.KategoriAd</td>
                <td>@(item.YayinlanmaTarihi?.ToString() ?? "Yayında Değil")</td>
                <td>@string.Join(", ", item.Etiketler)</td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="6" class="text-center fw-bold">Hiç makale bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>
